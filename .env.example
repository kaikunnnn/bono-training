# Supabase設定 (クライアントサイド)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase設定 (サーバーサイド)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# サイトURL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity Configuration (クライアントサイド)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-sanity-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity Configuration (サーバーサイド)
SANITY_PROJECT_ID=your-sanity-project-id
SANITY_DATASET=production
SANITY_WRITE_TOKEN=your_sanity_write_token_here

# Site URL for OGP (サーバーサイド)
SITE_URL=https://app.bo-no.design

# Webflow Configuration (サーバーサイド)
WEBFLOW_API_TOKEN=wf_your_api_token_here

# Webflow Collection IDs (クライアントサイド)
NEXT_PUBLIC_WEBFLOW_VIDEOS_COLLECTION_ID=6029d027f6cb8852cbce8c75
NEXT_PUBLIC_WEBFLOW_SERIES_COLLECTION_ID=your-series-collection-id

# Blog / Ghost CMS設定
NEXT_PUBLIC_BLOG_DATA_SOURCE=ghost
NEXT_PUBLIC_GHOST_URL=http://localhost:2368
NEXT_PUBLIC_GHOST_KEY=your_ghost_content_api_key_here

# Slack Webhook URL (サーバーサイド)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# Stripe設定
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
